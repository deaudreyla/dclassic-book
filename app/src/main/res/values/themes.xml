<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.DClassicBook" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.DClassicBook" parent="Base.Theme.DClassicBook">
        <item name="android:windowSplashScreenBackground">@color/backgroundBase</item>
    </style>

    <style name="HeroTitle">
        <item name="android:fontFamily">@font/merriweather_semibold</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textColor">@color/neutral200</item>
        <item name="android:lineHeight">40dp</item>
    </style>

    <style name="IntroTitle">
        <item name="android:fontFamily">@font/montserrat_bold</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/neutral200</item>
        <item name="android:lineHeight">36dp</item>
    </style>

    <style name="Title">
        <item name="android:fontFamily">@font/merriweather_regular</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/neutral200</item>
        <item name="android:lineHeight">36dp</item>
    </style>

    <style name="Heading1">
        <item name="android:fontFamily">@font/montserrat_semibold</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/neutral200</item>
        <item name="android:lineHeight">36dp</item>
    </style>

    <style name="Heading2">
        <item name="android:fontFamily">@font/montserrat_semibold</item>
        <item name="android:textStyle">normal</item>
