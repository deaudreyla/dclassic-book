<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".application.handler.ui.BookListActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/bg_screen_gradient"
            android:fitsSystemWindows="true">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <ImageView
                        android:id="@+id/btnHamburg"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_nav_hamburg"
                        android:clickable="true"
                        android:focusable="true"
                        tools:ignore="ContentDescription" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_nav_profile"
                        android:clickable="true"
                        android:focusable="true"
                        tools:ignore="ContentDescription" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Books Collection"
                    android:textAppearance="@style/Title" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_tab_container"
                    android:paddingHorizontal="5dp"
                    android:paddingVertical="4dp">

                    <TextView
                        android:id="@+id/tabFiction"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:paddingVertical="8dp"
                        android:gravity="center"
                        android:text="Fiction"
                        android:background="@drawable/bg_tab_active"
                        android:textAppearance="@style/Heading3"
                        android:textColor="@color/neutral10"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tabNonFiction"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:paddingVertical="8dp"
                        android:gravity="center"
                        android:text="Non-Fiction"
                        android:background="@drawable/bg_tab_inactive"
                        android:textAppearance="@style/Heading3"
                        android:textColor="@color/neutral50"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

            </LinearLayout>

            <!-- ViewPager2 -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPager"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

        <include layout="@layout/layout_navbar" />

    </FrameLayout>

    <include layout="@layout/layout_sidebar" />

</androidx.drawerlayout.widget.DrawerLayout>
