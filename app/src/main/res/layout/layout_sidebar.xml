<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="260dp"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    android:background="@color/accent150"
    android:orientation="vertical"
    android:paddingStart="27dp"
    android:paddingEnd="27dp"
    android:paddingTop="60dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_booklist"
            android:tint="@color/primary50"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="D\'Classics Books"
            android:textAppearance="@style/Heading3"
            android:textColor="@color/primary50" />

    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="51dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/sidebarHome"
            android:layout_width="match_parent"
            android:layout_height="39dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="13dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iconHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_home_selector"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/textHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Home"
                android:textAppearance="@style/Heading3"
                android:textColor="@color/accent10" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/sidebarBookList"
            android:layout_width="match_parent"
            android:layout_height="39dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="13dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iconBookList"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_booklist_selector"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/textBookList"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Book List"
                android:textAppearance="@style/Heading3"
                android:textColor="@color/accent10" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/sidebarOurStores"
            android:layout_width="match_parent"
            android:layout_height="39dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="13dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iconOurStores"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_ourstore_selector"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/textOurStores"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Our Stores"
                android:textAppearance="@style/Heading3"
                android:textColor="@color/accent10" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/sidebarLogout"
            android:layout_width="match_parent"
            android:layout_height="39dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="13dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_logout"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Log Out"
                android:textAppearance="@style/Heading3"
                android:textColor="@color/dangerText" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
