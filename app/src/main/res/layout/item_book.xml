<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="277dp">

    <View
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_card_gradient" />

    <ImageView
        android:id="@+id/ivCover"
        android:layout_width="130dp"
        android:layout_height="175dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="25dp"
        android:background="@drawable/bg_image_cover"
        android:clipToOutline="true"
        android:elevation="2dp"
        android:scaleType="centerCrop"
        tools:ignore="ContentDescription" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:paddingTop="12dp"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:lineSpacingExtra="0dp"
            android:maxLines="1"
            android:textAppearance="@style/Heading2"
            android:textColor="@color/neutral200"
            tools:text="Atomic Habits" />

        <TextView
            android:id="@+id/tvAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/SubHeading1"
            android:textColor="@color/neutral200"
            tools:text="James Clear" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/llStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textAppearance="@style/BodySmall"
                android:textColor="@color/neutral100"
                tools:text="4" />

            <TextView
                android:id="@+id/tvUserCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:lineSpacingExtra="0dp"
                android:textAppearance="@style/Caption"
                android:textColor="@color/neutral100"
                tools:text="(2k users)" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
