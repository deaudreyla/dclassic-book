<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login">

    <!-- App Logo -->
    <FrameLayout
        android:id="@+id/flLogo"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginStart="54dp"
        android:layout_marginTop="93dp"
        android:background="@drawable/bg_logo_box"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="10dp"
            android:src="@drawable/ic_app"
            tools:ignore="ContentDescription" />

    </FrameLayout>

    <!-- Welcome Back! -->
    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="54dp"
        android:layout_marginTop="26dp"
        android:layout_marginEnd="20dp"
        android:text="Welcome\nBack!"
        android:textAppearance="@style/HeroTitle"
        android:textColor="@color/accent200"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/flLogo" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="241dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="54dp"
        android:layout_marginTop="12dp"
        android:text="Let's continue your book shopping in D'Classics Books, enjoy!"
        android:textAppearance="@style/SubHeading1"
        android:textColor="@color/accent200"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome" />

    <!-- Guideline at 43% from top -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/glCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.5" />

    <!-- White card -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_login_card"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="36dp"
        android:paddingEnd="20dp"
        android:paddingBottom="36dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/glCard"
        app:layout_constraintVertical_bias="1.0">

        <!-- Username Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Username"
            android:textAppearance="@style/BodyLarge"
            android:textColor="@color/neutral200" />

        <!-- Username Input -->
        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_input_field"
            android:hint="Input Here (E.g : John Doe)"
            android:inputType="text"
            android:paddingStart="23dp"
            android:paddingTop="14dp"
            android:paddingEnd="23dp"
            android:paddingBottom="14dp"
            android:singleLine="true"
            android:textAppearance="@style/Placeholder"
            android:textColor="@color/neutral200"
            android:textColorHint="@color/neutral50" />

        <TextView
            android:id="@+id/tvUsernameError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/BodySmall"
            android:textColor="@color/dangerText"
            android:visibility="gone" />

        <!-- Password Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Password"
            android:textAppearance="@style/BodyLarge"
            android:textColor="@color/neutral200" />

        <!-- Password Input Row -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp">

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_field"
                android:hint="Input Here"
                android:inputType="textPassword"
                android:paddingStart="23dp"
                android:paddingTop="14dp"
                android:paddingEnd="50dp"
                android:paddingBottom="14dp"
                android:singleLine="true"
                android:textAppearance="@style/Placeholder"
                android:textColor="@color/neutral200"
                android:textColorHint="@color/neutral50" />

            <ImageView
                android:id="@+id/ivEyeToggle"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="17dp"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_eye"
                tools:ignore="ContentDescription" />

        </FrameLayout>

        <TextView
            android:id="@+id/tvPasswordError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/BodySmall"
            android:textColor="@color/dangerText"
            android:visibility="gone" />

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Sign In Button -->
        <Button
            android:id="@+id/btnSignIn"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:background="@drawable/bg_button_primary"
            android:stateListAnimator="@null"
            android:text="Sign In"
            android:textAppearance="@style/PrimaryButton"
            android:textColor="@color/neutral10"
            app:backgroundTint="@null" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
