<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="200dp"
    android:layout_height="316dp"
    android:layout_marginEnd="12dp"
    android:clipChildren="false">

    <!-- Gradient card background — bottom portion -->
    <View
        android:layout_width="match_parent"
        android:layout_height="190dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_featured_book_card" />

    <!-- Book cover — centered horizontally, anchored to top -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:clipChildren="false"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/ivFeaturedCover"
            android:layout_width="148dp"
            android:layout_height="200dp"
            android:background="@drawable/bg_image_cover"
            android:clipToOutline="true"
            android:elevation="4dp"
            android:scaleType="centerCrop"
            tools:ignore="ContentDescription"
            tools:src="@drawable/img_bookcover_atomichabits" />

    </LinearLayout>

    <!-- Rank badge — top-left corner of cover -->
    <TextView
        android:id="@+id/tvRank"
        android:layout_width="26dp"
        android:layout_height="32dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="26dp"
        android:layout_marginTop="0dp"
        android:background="@drawable/bg_rank_badge"
        android:fontFamily="@font/merriweather_regular"
        android:gravity="center"
        android:lineSpacingExtra="0dp"
        android:textColor="@color/primary10"
        android:textSize="16sp"
        tools:text="1" />

    <!-- Text info — bottom of card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvFeaturedTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:lineSpacingExtra="0dp"
            android:maxLines="1"
            android:textAppearance="@style/Heading2"
            android:textColor="@color/neutral200"
            tools:text="Atomic Habits" />

        <TextView
            android:id="@+id/tvFeaturedAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="0dp"
            android:textAppearance="@style/SubHeading1"
            android:textColor="@color/neutral200"
            tools:text="James Clear" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/llFeaturedStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

            <TextView
                android:id="@+id/tvFeaturedCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:lineSpacingExtra="0dp"
                android:textAppearance="@style/Caption"
                android:textColor="@color/neutral100"
                tools:text="(2k users)" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
