<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="253dp"
    android:layout_marginStart="0dp"
    android:layout_marginEnd="0dp"
    android:background="@drawable/bg_store_card"
    android:clipToOutline="true"
    android:elevation="2dp"
    android:outlineAmbientShadowColor="#29000000"
    android:outlineSpotShadowColor="#29000000">

    <ImageView
        android:id="@+id/ivCarouselStore"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        tools:ignore="ContentDescription"
        tools:src="@drawable/img_store_central" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_store_gradient" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="18dp">

        <TextView
            android:id="@+id/tvCarouselStoreName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:lineSpacingExtra="0dp"
            android:maxLines="1"
            android:textAppearance="@style/Heading2"
            android:textColor="@color/neutral200"
            tools:text="Central D'Classic" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_location"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tvCarouselStoreLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:lineSpacingExtra="0dp"
                android:maxLines="1"
                android:textAppearance="@style/Caption"
                android:textColor="@color/neutral100"
                tools:text="Jl. M.H. Thamrin No. 1, Menteng" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
