<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/backgroundBase" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/secondary50"
                android:centerColor="@color/backgroundBase"
                android:endColor="@color/backgroundBase"
                android:centerX="0.2"
                android:centerY="0.5" />
        </shape>
    </item>
</layer-list>
